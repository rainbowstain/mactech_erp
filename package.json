{
  "name": "mactech-erp",
  "private": true,
  "version": "1.1.1",
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3001",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port 3001",
    "db:migrate": "node --env-file=.env.local scripts/migrate-from-mysql.mjs",
    "db:setup-empty": "node --env-file=.env.local scripts/setup-empty-db.mjs",
    "db:setup-empty:prod": "node --env-file=.env.production.local scripts/setup-empty-db.mjs",
    "db:verify": "node --env-file=.env.local scripts/verify-data.mjs",
    "db:verify:prod": "node --env-file=.env.production.local scripts/verify-data.mjs",
    "inventory:import": "node --env-file=.env.local scripts/import-inventory.mjs",
    "finance:setup": "node --env-file=.env.local scripts/setup-finance.mjs",
    "users:setup": "node --env-file=.env.local scripts/setup-users.mjs",
    "catalog:reset": "node --env-file=.env.local scripts/reset-device-catalog.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "gsap": "^3.15.0",
    "jose": "^5.10.0",
    "lucide-react": "^0.468.0",
    "mysql2": "^3.11.5",
    "next": "^16.2.7",
    "pg": "^8.13.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "sonner": "^2.0.7"
  },
  "overrides": {
    "postcss": "^8.5.15"
  },
  "devDependencies": {
    "playwright-core": "^1.60.0"
  }
