DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54323/mactech_erp
SESSION_SECRET=change-this-secret

# Supabase/Vercel:
# DATABASE_URL debe ser el connection string Postgres o Supavisor Pooler.
# En produccion recomienda usar el pooler transaction/session de Supabase.
# PGSSLMODE=require fuerza SSL si tu host no es detectado automaticamente.
# PGSSLMODE=require

# Solo para inicializar una BD limpia con npm run db:setup-empty
RESET_EMPTY_DB_CONFIRM=SI
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=change-this-admin-password

# Solo para migrar desde el sistema legacy/MySQL local
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_DATABASE=istylest_istyle_store
MYSQL_USER=root
MYSQL_PASSWORD=root

NEXT_PUBLIC_ERP_NAME=MacTech ERP
# La web pública vive en el mismo dominio (raíz "/"). Dejar vacío para usar "/".
# Solo definir si la web estuviera en otro host.
NEXT_PUBLIC_WEB_URL=/
